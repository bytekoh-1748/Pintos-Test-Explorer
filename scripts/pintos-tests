#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." >/dev/null 2>&1 && pwd)"

if [[ -n "${PINTOS_PYTHON_PATH:-}" ]]; then
  exec "$PINTOS_PYTHON_PATH" "$ROOT_DIR/scripts/pintos-test-cli.py" "$@"
fi

if command -v python3 >/dev/null 2>&1; then
  exec python3 "$ROOT_DIR/scripts/pintos-test-cli.py" "$@"
fi

if command -v python >/dev/null 2>&1; then
  exec python "$ROOT_DIR/scripts/pintos-test-cli.py" "$@"
fi

if command -v py >/dev/null 2>&1; then
  exec py -3 "$ROOT_DIR/scripts/pintos-test-cli.py" "$@"
fi

echo "Could not find a Python interpreter. Install Python 3 or set PINTOS_PYTHON_PATH." >&2
exit 127
